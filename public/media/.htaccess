# public/media/ holds user-uploaded files (avatars, blog images, etc.).
# Defense-in-depth: even if a malicious upload slips past the validation
# in modules/Users/, modules/Media/, or theme upload, the web server must
# never execute anything in this tree as code.

# Disable PHP if the module is loaded.
<IfModule mod_php.c>
    php_flag engine off
</IfModule>
<IfModule mod_php7.c>
    php_flag engine off
</IfModule>
<IfModule mod_php8.c>
    php_flag engine off
</IfModule>

# Block direct access to script-like extensions regardless of server config.
# (case-insensitive)
<FilesMatch "(?i)\.(php[0-9]?|phtml|phar|phps|pht|inc|cgi|pl|py|jsp|asp|aspx|sh|bat|exe|htaccess|htpasswd|user\.ini|ini)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

# Prevent directory listing if an admin accidentally exposes a folder.
Options -Indexes

# Force browsers to honour the declared MIME type — no PHP-via-image-sniff.
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
</IfModule>
